# Credentials for the automated catalog sync (scripts/sync/sync.mjs).
# Copy to scripts/sync/.env and run:  node --env-file=scripts/sync/.env scripts/sync/sync.mjs
# In CI these are provided as GitHub Actions secrets/vars instead (see .github/workflows/catalog-sync.yml).

# --- Amazon Product Advertising API (PA-API 5.0) ---
# From https://webservices.amazon.com after you're an approved Associate with API access.
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=your_associates_tag-20
# Optional overrides (defaults target the US marketplace):
# AMAZON_HOST=webservices.amazon.com
# AMAZON_REGION=us-east-1
# AMAZON_MARKETPLACE=www.amazon.com

# --- AliExpress Affiliate Open Platform API ---
# From https://portals.aliexpress.com (Affiliate) + https://openservice.aliexpress.com app.
ALIEXPRESS_APP_KEY=
ALIEXPRESS_APP_SECRET=
ALIEXPRESS_TRACKING_ID=
# Optional overrides:
# ALIEXPRESS_TARGET_CURRENCY=USD
# ALIEXPRESS_TARGET_LANGUAGE=EN
# ALIEXPRESS_GATEWAY=https://api-sg.aliexpress.com/sync

# --- Opt-in structured-data reader for Kilimall / Jumia / Temu ---
# These have NO public product API. Reading JSON-LD off product pages is best-effort
# and ToS/robots-sensitive. Only enable after you've verified each site's terms.
SOKONI_ENABLE_SCRAPE=false
# SOKONI_SCRAPE_UA=SokoniCatalogBot/1.0 (+https://github.com/Murphy601/sokoni)
# SOKONI_SCRAPE_TIMEOUT_MS=15000
