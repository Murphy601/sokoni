# --- WAHA (WhatsApp HTTP API — self-hosted, NOT Meta Cloud API) ---
# Run WAHA with Docker (see docs/GO_LIVE_WAHA.md), then point these at your instance.
WAHA_API_URL=http://localhost:3000
WAHA_API_KEY=sokoni-local-dev-key
WAHA_SESSION=default

# --- AI via OpenRouter (OpenAI-compatible) ---
OPENAI_API_KEY=your_openrouter_api_key
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=nvidia/nemotron-nano-9b-v2:free
# Vision model for reading product photos (OpenRouter — must support image input)
CATALOG_VISION_MODEL=google/gemini-2.5-flash
# Fallbacks if primary fails (comma-separated)
CATALOG_VISION_FALLBACKS=google/gemini-2.0-flash-exp:free,google/gemini-2.5-flash-lite
# Auto git commit+push after WhatsApp catalog changes (enable on GCP VM)
CATALOG_AUTO_PUSH=true
# Git identity for catalog commits from the VM (required for auto-push)
GIT_AUTHOR_NAME=sokoni-bot
GIT_AUTHOR_EMAIL=bot@sokonimall.com
# Wait before rebuild/push when batching many photos (milliseconds)
CATALOG_PUBLISH_DEBOUNCE_MS=30000

# --- App ---
PORT=3001
PUBLIC_SITE_URL=https://sokonimall.com
# Bot HTTPS URL — WhatsApp product images (served from /catalog-images on the VM)
BOT_PUBLIC_URL=https://bot.sokonimall.com

# --- Affiliate sub-IDs (optional — international affiliate items only) ---
KILIMALL_AFFILIATE_ID=your_kilimall_affiliate_id
JUMIA_AFFILIATE_ID=your_jumia_kol_affiliate_id
ALIEXPRESS_AFFILIATE_ID=your_aliexpress_affiliate_id
TEMU_AFFILIATE_ID=your_temu_affiliate_id
AMAZON_AFFILIATE_TAG=your_amazon_associates_tag

# --- Store / COD ---
STORE_MARKUP_KES=100
STORE_COD_AREAS=Nairobi & environs
STORE_DELIVERY_NOTE=Delivery in 1-3 days within Nairobi; countrywide via courier. Pay via M-Pesa Till on delivery.
MPESA_TILL_NUMBER=4775847
MPESA_TILL_NAME=David Thuku Muiruri
BUSINESS_WHATSAPP_NUMBER=254117422428

# --- Ops (optional extra webhook for orders/handoffs) ---
ADMIN_NOTIFY_URL=
# Admin console phone(s), comma-separated. Use a DIFFERENT number from the bot:
# order/handoff alerts go here, and messages from here are treated as admin
# commands (#orders, #status, #broadcast, # reply). Only these numbers get admin access.
ADMIN_PHONES=254757764009

# --- TikTok auto-posting (backend only — not shown on website) ---
# Get credentials from developers.tiktok.com (Content Posting API + Login Kit).
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:3001/admin/tiktok/callback
TIKTOK_SCOPES=user.info.basic,video.publish
# One-time setup secret for /admin/tiktok/connect (any long random string)
TIKTOK_SETUP_TOKEN=
# URL-prefix verification line from TikTok portal (tiktok....txt file contents)
TIKTOK_VERIFY_SIGNATURE=
# Optional bootstrap only — after OAuth, tokens live in data/tiktok-oauth.json
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=
TIKTOK_CRON_ENABLED=false
# Post times in EAT (Africa/Nairobi): 8:00 AM, 1:00 PM, 7:30 PM
TIKTOK_POST_TIMES=08:00,13:00,19:30
TIKTOK_TIMEZONE=Africa/Nairobi
# SELF_ONLY until app audit; then PUBLIC_TO_EVERYONE
TIKTOK_PRIVACY_LEVEL=SELF_ONLY
