# --- WhatsApp Cloud API (Meta for Developers) ---
# Create an app at https://developers.facebook.com/apps, add the "WhatsApp" product,
# and grab these from the WhatsApp > API Setup page.
WHATSAPP_ACCESS_TOKEN=your_meta_whatsapp_cloud_api_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_waba_id
# Any string you choose — must match what you enter in the Meta webhook config UI.
WHATSAPP_VERIFY_TOKEN=choose_a_random_verify_token
WHATSAPP_API_VERSION=v21.0

# --- AI provider ---
# Any OpenAI-compatible chat completions API key/model works here.
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# --- App ---
PORT=3000

# --- Affiliate sub-IDs (your tracking IDs from each program's dashboard) ---
KILIMALL_AFFILIATE_ID=your_kilimall_affiliate_id
JUMIA_AFFILIATE_ID=your_jumia_kol_affiliate_id
ALIEXPRESS_AFFILIATE_ID=your_aliexpress_affiliate_id
TEMU_AFFILIATE_ID=your_temu_affiliate_id
AMAZON_AFFILIATE_TAG=your_amazon_associates_tag

# --- Ops ---
# Where the bot notifies you when a chat needs a human (e.g. your own WhatsApp number,
# or wired later to Slack/Telegram). Optional for local dev.
ADMIN_NOTIFY_URL=
